[
  {
    "description": "List files in the workspace directory.",
    "input_schema": {
      "properties": {
        "path": {
          "description": "Root directory to list (default '.').",
          "type": "string"
        },
        "recursive": {
          "description": "Recurse into subdirectories.",
          "type": "boolean"
        }
      },
      "required": [],
      "type": "object"
    },
    "name": "list_files"
  },
  {
    "description": "Read a file from the workspace.",
    "input_schema": {
      "properties": {
        "end_line": {
          "description": "Last line to include (1-based).",
          "type": "integer"
        },
        "path": {
          "description": "File path to read.",
          "type": "string"
        },
        "start_line": {
          "description": "First line to include (1-based).",
          "type": "integer"
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "name": "read_file"
  },
  {
    "description": "Write text to an existing file in the workspace.",
    "input_schema": {
      "properties": {
        "content": {
          "description": "Full replacement file content.",
          "type": "string"
        },
        "path": {
          "description": "Existing file path to overwrite.",
          "type": "string"
        }
      },
      "required": [
        "path",
        "content"
      ],
      "type": "object"
    },
    "name": "write_file"
  },
  {
    "description": "Create a new file in the workspace.",
    "input_schema": {
      "properties": {
        "content": {
          "description": "Initial file content.",
          "type": "string"
        },
        "path": {
          "description": "New file path to create.",
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "name": "create_file"
  },
  {
    "description": "Search for text in workspace files.",
    "input_schema": {
      "properties": {
        "glob_pattern": {
          "description": "Optional glob to filter filenames (e.g. '*.py').",
          "type": "string"
        },
        "path": {
          "description": "Root directory to search (default '.').",
          "type": "string"
        },
        "query": {
          "description": "Text to search for.",
          "type": "string"
        }
      },
      "required": [
        "query"
      ],
      "type": "object"
    },
    "name": "search_code"
  },
  {
    "description": "Apply a unified diff patch to workspace files.",
    "input_schema": {
      "properties": {
        "diff": {
          "description": "Unified diff string to apply.",
          "type": "string"
        }
      },
      "required": [
        "diff"
      ],
      "type": "object"
    },
    "name": "apply_patch"
  },
  {
    "description": "Execute a controlled command within the workspace.",
    "input_schema": {
      "properties": {
        "command": {
          "description": "Command string parsed as argv; shell control syntax is not allowed.",
          "type": "string"
        },
        "cwd": {
          "description": "Working directory for the command (must be within workspace).",
          "type": "string"
        },
        "timeout": {
          "description": "Timeout in seconds (default 60).",
          "type": "integer"
        }
      },
      "required": [
        "command"
      ],
      "type": "object"
    },
    "name": "run_command"
  },
  {
    "description": "Run a Python script or a narrow allowed Python test module inside the workspace.",
    "input_schema": {
      "properties": {
        "args": {
          "description": "Command-line args passed to the script or module.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "cwd": {
          "description": "Working directory for execution (must remain in workspace).",
          "type": "string"
        },
        "run_as_module": {
          "description": "When true, run `python -m <target>` for an allowed module.",
          "type": "boolean"
        },
        "target": {
          "description": "Workspace .py file, or an allowed module name.",
          "type": "string"
        },
        "timeout": {
          "description": "Timeout in seconds (default 60).",
          "type": "integer"
        }
      },
      "required": [
        "target"
      ],
      "type": "object"
    },
    "name": "python_run"
  },
  {
    "description": "Signal task completion with an optional answer.",
    "input_schema": {
      "properties": {
        "answer": {
          "description": "Final answer or description of what was done.",
          "type": "string"
        },
        "summary": {
          "description": "Optional summary of the solution.",
          "type": "string"
        }
      },
      "required": [],
      "type": "object"
    },
    "name": "finish"
  }
]